# Portfolio Django Backend - Configuration d'environnement
# Copier ce fichier en .env et remplir avec vos valeurs
# ⚠️ IMPORTANT: Ne jamais commiter .env (il contient des secrets)

# ========================================
# DJANGO CORE
# ========================================
DEBUG=True
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire-ici
ALLOWED_HOSTS=localhost,127.0.0.1

# ========================================
# BASE DE DONNÉES
# ========================================
# Développement: utilisé par défaut (SQLite)
# Production: remplacer par PostgreSQL ou MySQL
DATABASE_URL=sqlite:///db.sqlite3

# ========================================
# CORS & SÉCURITÉ
# ========================================
# Frontend URL (pour CORS)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# ========================================
# EMAIL (Configuration Gmail)
# ========================================
# Pour utiliser Gmail:
# 1. Activer l'authentification à 2 facteurs
# 2. Génerer un "mot de passe d'application": https://myaccount.google.com/apppasswords
# 3. Remplir EMAIL_HOST_USER et EMAIL_HOST_PASSWORD

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-application

# Optionnel: adresse email par défaut pour les notifications
DEFAULT_FROM_EMAIL=votre-email@gmail.com

# ========================================
# PRODUCTION (À ADAPTER)
# ========================================
# Décommenter et adapter pour la production
# DEBUG=False
# SECRET_KEY=votre-nouvelle-cle-secrete-production
# ALLOWED_HOSTS=votre-domaine.com
# DATABASE_URL=postgresql://user:password@host:port/dbname

